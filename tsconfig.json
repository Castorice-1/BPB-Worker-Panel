{
    "include": ["src"],
    "compilerOptions": {
        "target": "ESNext",
        "module": "ESNext",
        "types": ["@cloudflare/workers-types"],
        /* 核心修复：使用现代化模块解析，不再使用废弃的 node10/baseUrl */
        "moduleResolution": "bundler",
        
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "resolveJsonModule": true,
        "isolatedModules": true,
        "noEmit": true,

        /* 路径映射：全部基于项目根目录 */
        "paths": {
            /* 基础模块映射 (解决 Error TS2307) */
            "auth": ["./src/auth"],
            "kv": ["./src/kv"],
            "types/*": ["./src/types/*"],

            /* 别名映射 */
            "@xray/*": ["./src/cores/xray/*"],
            "@sing-box/*": ["./src/cores/sing-box/*"],
            "@clash/*": ["./src/cores/clash/*"],
            "@utils": ["./src/cores/utils"],
            "@handlers": ["./src/common/handlers"],
            "@init": ["./src/common/init"],
            "@common": ["./src/common/common"],
            "@vless": ["./src/protocols/websocket/vless"],
            "@trojan": ["./src/protocols/websocket/trojan"],
            "@warp": ["./src/protocols/warp"]
        }
    }
}
